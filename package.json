{
  "name": "agentlink",
  "version": "0.1.0",
  "description": "Local agent that proxies a working directory to a cloud web interface",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yilee/agentlink.git"
  },
  "homepage": "https://github.com/yilee/agentlink",
  "bugs": {
    "url": "https://github.com/yilee/agentlink/issues"
  },
  "type": "module",
  "workspaces": [
    "server",
    "agent"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:server": "npm run dev --workspace=server",
    "dev:agent": "npm run dev --workspace=agent",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:agent\"",
    "start:server": "npm run start --workspace=server",
    "start:agent": "npm run start --workspace=agent",
    "clean": "rimraf server/dist agent/dist",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^8.2.2",
    "playwright": "^1.58.2",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
